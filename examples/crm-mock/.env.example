# JWT_SECRET DEBE coincidir con docker/.env.local
JWT_SECRET=

# Host accesible desde DENTRO del contenedor del DocumentServer
# - En Docker Desktop (Windows/Mac): host.docker.internal:3000
# - En Linux nativo: 172.17.0.1:3000 (gateway docker0)
# - En EC2: dominio público del CRM
PUBLIC_HOST=host.docker.internal:3000

PORT=3000
