# Default: detect text/binary, force LF line endings
* text=auto eol=lf

# Shell scripts must be LF (Linux containers fail with CRLF)
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts stay CRLF (Windows-only)
*.ps1 text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.7z binary
*.docx binary
*.xlsx binary
*.pptx binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
